{
  "name": "gtfs-validator-backend",
  "version": "1.0.0",
  "description": "Backend API para GTFS Validator con BullMQ y PostGIS",
  "main": "src/api/server.js",
  "type": "module",
  "scripts": {
    "start": "concurrently \"node src/api/server.js\" \"node src/worker/index.js\"",
    "dev:api": "node --watch src/api/server.js",
    "dev:worker": "node --watch src/worker/index.js",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:worker\"",
    "db:clean": "node scripts/cleanup.js"
  },
  "dependencies": {
    "bullmq": "^5.7.8",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.5",
    "pg-copy-streams": "^6.0.6",
    "unzipper": "^0.12.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
